<td>
  <div class="c-lined-table__with-actions">
    <div class="c-lined-table__data" id="title_<%= j.id %>"><%= j.title %></div>
    <% if policy(j).edit? %>
    <div class="c-lined-table__with-actions">
      <% if j.flag.present? %>
        <span><i class="fas fa-flag jour" aria-label="Flagged" title="<%= j.flag.note %>"></i></span>
      <% end %>
      <%= form_with(url: journal_edit_path(id: j.id), method: :get, local: false) do %>
        <button class="c-admin-edit-icon" aria-label="Edit journal" aria-haspopup="dialog" id="edit_button_<%= j.id %>">
          <i class="fa fa-pencil" aria-hidden="true"></i>
        </button>
      <% end %>
    </div>
    <% end %>
  </div>
</td>
<td><%= j.issn_array.join(", ") %></td>
<td>
  <span style="color: <%= j.default_to_ppr ? '#3c763d' : 'rgb(209, 44, 29)'%>">
    <%= j.default_to_ppr ? "True" : "False" %>
  </span>
</td>
<td>
  <% if j.payment_sponsor&.payment_configuration&.payment_plan&.present? %>
    <b>Plan:</b> <%= j.payment_sponsor&.payment_configuration&.payment_plan&.humanize %><br/>
    <b>Covers LDF:</b> <%= j.sponsored_limits&.covers_ldf ? "Yes" : "No" %>
    <% if j.sponsored_limits&.covers_ldf %>
      <% if j.sponsored_limits&.ldf_limit&.present? %>
        (Up to <%= filesize(ESTIMATED_FILES_SIZE.find{|tier| tier[:tier] == j.sponsored_limits&.ldf_limit }[:range].max) %>)
      <% end %>
      <% if j.sponsored_limits&.yearly_ldf_limit&.present? %>
        <br/><b>Remaining LDF budget:</b> <%= j.sponsored_limits&.yearly_ldf_limit - j.sponsor&.payment_logs.sum(:ldf) %>
      <% end %>
    <% end %>
  <% end %>
</td>
<td>
  <% if j.sponsor_id.present? %>
    <a href="<%= publisher_admin_path(q: j.sponsor.name) %>"><%= j.sponsor.name %></a>
  <% end %>
</td>
<td>
  <% if j.payment_sponsor.present? && j.payment_sponsor.id != j.sponsor_id %>
    <a href="<%= publisher_admin_path(q: j.payment_sponsor&.name) %>"><%= j.payment_sponsor&.name %></a>
  <% end %>
</td>

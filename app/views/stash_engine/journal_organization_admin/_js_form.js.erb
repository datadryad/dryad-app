// open a modal dialog
document.getElementById('genericModalContent').innerHTML = "<%= escape_javascript(render partial: html_partial) %>";
document.getElementById('genericModalDialog').showModal();
document.getElementById('cancel_dialog').addEventListener('click', (e) => {
  e.preventDefault();
  document.getElementById('genericModalDialog').close();
});

var sponsor_id = document.getElementById('parent_org_id')
sponsor_id.addEventListener('change', () => {
  if (sponsor_id.value === '') {
    document.getElementById('payment_plan_container').removeAttribute('hidden');
    document.getElementById('payment_plan_notice').setAttribute('hidden', '');
  } else {
    document.getElementById('payment_plan_container').setAttribute('hidden', '');
    document.getElementById('payment_plan_notice').removeAttribute('hidden');
  }
});


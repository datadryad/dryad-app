document.getElementById('<%= @type %>_list').innerHTML = "<% current_user.send(@type.to_sym).each_with_index do |s,i| %><%= escape_javascript(render partial: 'saved_search', locals: { saved_search: s, index: i + 1 })%><% end %>"
document.getElementById('sub-status').innerHTML = ""
if (<%= (@saved_search.present? && @subscription).to_json %>) {
  document.getElementById('subscribe<%= @saved_search&.id %>').querySelector('button').focus();
  document.getElementById('sub-status').innerHTML = "<p>Subscription change successful for <%= @saved_search&.title %></p>"
} else if (document.getElementById('saved_search<%= @saved_search&.id %>')) {
  document.getElementById('saved_search<%= @saved_search&.id %>').querySelector('a').focus();
  document.getElementById('sub-status').innerHTML = "<p>Update successful</p>"
} else {
  document.getElementById('<%= @type %>_list').focus();
  document.getElementById('sub-status').innerHTML = "<p>Deletion successful</p>"
}
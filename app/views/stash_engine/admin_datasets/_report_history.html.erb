<h1>Action required report history</h1>
<% if @resources.present? %>
  Report for each version as displayed in the submission system.
<% else %>
  <p>No reports added yet.</p>
<% end %>
<% @resources.each do |resource| %>
  <h2 class="o-heading__level4">Version <%= resource.stash_version.version %>, ID <%= resource.id %></h2>
  <div class="callout warn">
    <p role="heading" aria-level="3"><i class="fa fa-triangle-exclamation" aria-hidden="true"></i> Action required</p>
    <p style="white-space: pre-wrap; font-size: .98rem"><%= resource.action_reports.last&.report %></p>
  </div>
<% end %>
<div class="c-modal__buttons-right">
  <%= button_tag 'Close', type: 'button', id: 'cancel_dialog', class: 'o-button__plain-text7' %>
</div>
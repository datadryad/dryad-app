<h1 id="dialog-title">Action required report</h1>
<%= form_with(url: make_report_path(id: @resource&.id), method: :post, local: false) do %>    
  <% if @resource.id != @identifier.latest_resource.id %>
    <div class="callout warn">
      <p>This report will be applied to the previous AAR version (<%= @resource.id %>)</p>
    </div>
  <% end %>
  <div class="c-input">
    <label class="input-label" for="report">List errors for the author to review.</label>
    <p style="margin: .5ch auto;">Queries may be copied from Salesforce email. This will appear at the top of the submission preview when the author revises their dataset.</p>
    <%= text_area_tag :report, @report || @text, class: 'c-input__textarea', style: 'width: 100%', rows: 10, "aria-labelledby": "" %>
  </div>
  <div class="c-input">
    <% unless @report.present? %>
      <label class="input-label" for="note">Curation note</label>
      <%= text_area_tag :note, @note, class: 'c-input__textarea', style: 'width: 100%' %>
    <% end %>
  </div>
  <p class="c-modal__buttons-right">
    <%= submit_tag 'Submit & set to Action required', class: 'o-button__plain-text2', id: 'popup_submit' %>
    <%= button_tag 'Cancel', type: 'button', id: 'cancel_dialog', class: 'o-button__plain-text7' %>
  </p>
<% end %>